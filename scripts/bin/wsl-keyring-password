#!/usr/bin/env bash
set -euo pipefail

target="${1:-${WSL_KEYRING_CRED_TARGET:-WSL-GNOME-Keyring}}"
target_escaped=${target//\'/\'\'}

password="$(
    powershell.exe -NoProfile -Command "
\$target = '$target_escaped'
\$module = Get-Module -ListAvailable CredentialManager | Select-Object -First 1
if (-not \$module) { exit 10 }
Import-Module CredentialManager
\$cred = Get-StoredCredential -Target \$target
if (-not \$cred) { exit 11 }
[Console]::Out.Write(\$cred.GetNetworkCredential().Password)
" 2>/dev/null
)"

printf '%s' "${password//$'\r'/}"
